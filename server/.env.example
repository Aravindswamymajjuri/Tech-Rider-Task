# Copy to .env and edit as needed.
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=please-change-me-to-a-long-random-string
# If MONGODB_URI is omitted the server will boot an in-memory MongoDB
# (mongodb-memory-server) so the app works without local DB setup.
# MONGODB_URI=mongodb://localhost:27017/onecrore

# === OAuth (optional) ===
# Sign in with Google: https://console.cloud.google.com/apis/credentials

# Set the OAuth redirect URI to: <API_ORIGIN>/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Sign in with Microsoft: https://entra.microsoft.com → App registrations
# Set the redirect URI to: <API_ORIGIN>/api/auth/microsoft/callback
# If the app is restricted to "My organization only", set MICROSOFT_TENANT_ID
# to your Directory (tenant) ID — leave unset for multi-tenant ("common").
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=

# Optional: override the public API origin if it differs from the request host
# (e.g. when running behind a proxy). Defaults to the request host.
# API_ORIGIN=http://localhost:5173
